rules_version = '2';

/**
 * Production trust model:
 * - Admin: custom claim admin == true (Firebase Auth custom token from Cloud Function)
 * - Customer: custom claim customerId (ח.פ.) matching resource
 * - Orders / prices: created only via Cloud Function (Admin SDK)
 * - app_settings/main: secrets + counters — never world-readable
 * - app_settings/public: site copy + VAT/min order — public read
 *
 * After first deploy: sign in as admin, then call ensurePublicAppSettings once (or copy doc in console).
 */
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isCustomer() {
      return isSignedIn() && request.auth.token.customerId is string;
    }

    function tokenCustomerId() {
      return request.auth.token.customerId;
    }

    /** Public catalog & marketing copy */
    match /app_settings/public {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /app_settings/main {
      allow read, write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if isAdmin() || (isCustomer() && tokenCustomerId() == customerId);
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isCustomer() && resource.data.customerId == tokenCustomerId());
      allow create, delete: if false;

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'paymentStatus']);
    }

    match /expenses/{expId} {
      allow read, write: if isAdmin();
    }

    match /productCosts/{id} {
      allow read, write: if isAdmin();
    }

    match /suppliers/{id} {
      allow read, write: if isAdmin();
    }

    match /transactions/{id} {
      allow read, write: if isAdmin();
    }

    match /quote_requests/{docId} {
      allow read: if isAdmin();
      allow create, update: if isCustomer()
        && request.resource.data.customerId == tokenCustomerId();
      allow delete: if isAdmin();
    }

    match /product_requests/{docId} {
      allow read: if isAdmin();
      allow create: if isCustomer()
        && request.resource.data.customerId == tokenCustomerId();
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
